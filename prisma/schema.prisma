generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id           Int      @id @default(autoincrement())
  title        String
  category     String
  price        String
  oldPrice     String
  discount     String
  image        String
  rating       Int
  store        String
  installments String
  shipping     String
  affiliate    String   @unique
  createdAt    DateTime @default(now())
}

model Customer {
  id                Int               @id @default(autoincrement())
  name              String
  email             String            @unique
  username          String?           @unique
  passwordHash      String
  termsAcceptedAt   DateTime?
  privacyAcceptedAt DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  sessions          CustomerSession[]
  lessonProgress    LessonProgress[]
}

model LessonProgress {
  id          Int      @id @default(autoincrement())
  customerId  Int
  lessonSlug  String
  completedAt DateTime @default(now())
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([customerId, lessonSlug])
  @@index([customerId])
}

model CustomerSession {
  id         String    @id
  customerId Int
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?
  customer   Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([expiresAt])
}

model AdminSession {
  id         String    @id
  createdAt  DateTime  @default(now())
  lastSeenAt DateTime  @default(now())
  expiresAt  DateTime
  revokedAt  DateTime?

  @@index([expiresAt])
}

model AuthThrottle {
  id              String    @id
  attempts        Int       @default(0)
  windowStartedAt DateTime
  blockedUntil    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([blockedUntil])
}

model SecurityEvent {
  id          String   @id @default(cuid())
  kind        String
  success     Boolean
  subjectHash String?
  ipHash      String?
  createdAt   DateTime @default(now())

  @@index([kind, createdAt])
  @@index([createdAt])
}
