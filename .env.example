# Vitalino Tech
NEXT_PUBLIC_SITE_NAME="TechOfertas"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_MERCADO_LIVRE_AFFILIATE_ID="coloque-seu-id-aqui"

# PostgreSQL. Use a conexão fornecida pelo seu provedor (Neon, Prisma Postgres etc.).
DATABASE_URL="postgresql://usuario:senha@host:5432/techofertas?sslmode=require"

# Acesso ao painel administrativo. Nunca envie os valores reais ao GitHub.
ADMIN_EMAIL="seu-email@exemplo.com"
ADMIN_PASSWORD="crie-uma-senha-forte"
AUTH_SECRET="gere-uma-chave-aleatoria-com-pelo-menos-32-caracteres"
# Opcional: ative o segundo fator com `npm run mfa:setup` e cadastre a chave no Vercel.
ADMIN_TOTP_SECRET=""

# Sincronização automática dos 20 mais vendidos (npm run bestsellers:sync).
# Crie um app em developers.mercadolivre.com.br para obter client_id/client_secret.
# MERCADO_LIVRE_REFRESH_TOKEN só é necessário na primeira execução: depois disso
# o próprio script guarda o token renovado no banco de dados.
MERCADO_LIVRE_CLIENT_ID=""
MERCADO_LIVRE_CLIENT_SECRET=""
MERCADO_LIVRE_REFRESH_TOKEN=""
# Parâmetros de afiliado (matt_word e matt_tool) obtidos resolvendo um dos
# seus links meli.la ou gerando um novo em mercadolivre.com.br/l/afiliados-home
MERCADO_LIVRE_MATT_WORD=""
MERCADO_LIVRE_MATT_TOOL=""
