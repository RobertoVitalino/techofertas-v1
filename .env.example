# Vitalino Tech
NEXT_PUBLIC_SITE_NAME="TechOfertas"
# Usado no sitemap, robots.txt e nas tags Open Graph. Na Vercel, defina como
# o domínio real do site (ex: "https://www.techofertas.com.br").
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# PostgreSQL. Use a conexão fornecida pelo seu provedor (Neon, Prisma Postgres etc.).
DATABASE_URL="postgresql://usuario:senha@host:5432/techofertas?sslmode=require"

# Acesso ao painel administrativo. Nunca envie os valores reais ao GitHub.
ADMIN_EMAIL="seu-email@exemplo.com"
ADMIN_PASSWORD="crie-uma-senha-forte"
AUTH_SECRET="gere-uma-chave-aleatoria-com-pelo-menos-32-caracteres"
# Opcional: ative o segundo fator com `npm run mfa:setup` e cadastre a chave no Vercel.
ADMIN_TOTP_SECRET=""
